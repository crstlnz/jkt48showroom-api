{
  "version": "0.13.4",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "bun run --hot src/index.ts",
    "build": "rimraf ./.output && bun build ./src/index.ts --outdir ./.output --target bun",
    "docker:build": "docker build -t crstlnz/api:latest .",
    "docker:push": "docker push crstlnz/api:latest",
    "docker": "bun docker:build && bun docker:push",
    "start": "bun .output/index.js"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.0.4",
    "cbor-x": "^1.6.0",
    "cli-progress": "^3.12.0",
    "cloudinary": "^2.5.1",
    "cron": "^3.1.7",
    "dayjs": "^1.11.12",
    "defu": "^6.1.4",
    "dotenv": "^16.4.5",
    "fuse.js": "^7.0.0",
    "hono": "^4.12.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mongoose": "8.19.3",
    "node-cloudflare-r2": "^0.5.1",
    "node-html-parser": "^6.1.13",
    "ofetch": "^1.3.4",
    "sharp": "^0.34.5",
    "string-comparison": "^1.3.0",
    "vue-virtual-sortable": "^3.0.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@antfu/eslint-config": "6.2.0",
    "@types/bun": "^1.3.1",
    "@types/cli-progress": "^3.11.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.13",
    "eslint": "9.39.0",
    "rimraf": "^6.0.1",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3"
  }
}
